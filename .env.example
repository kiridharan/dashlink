# =============================================================================
# DashLink — Environment variables
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local` (it's gitignored by default in Next.js).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# Get these from https://supabase.com → your project → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Use ONE of the two public keys below (publishable preferred on new projects).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Service-role key — server-only. Used by cron jobs to bypass RLS when
# evaluating scheduled alerts. NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# Public origin used to build embed URLs and alert email links.
# Examples:
#   http://localhost:3000
#   https://dashlink.example.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Cron / Scheduled alerts
# -----------------------------------------------------------------------------
# Shared secret protecting POST /api/cron/check-alerts.
# Required in production. Sent as `Authorization: Bearer <CRON_SECRET>`.
# Vercel Cron requests are also accepted via the `x-vercel-cron: 1` header.
CRON_SECRET=""

# -----------------------------------------------------------------------------
# Email (optional — enables alert email delivery via Resend)
# https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="DashLink <alerts@dashlink.app>"
